{
  "buildCommand": "echo 'No build needed - static files only'",
  "installCommand": "echo 'No dependencies needed'",
  "outputDirectory": ".",
  "trailingSlash": false,
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/mobile",
      "dest": "/mobile-server.html"
    },
    {
      "src": "/unified",
      "dest": "/unified.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client.html"
    }
  ]
}
