{
  "version": 2,
  "builds": [
    {
      "src": "client.html",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard.html",
      "use": "@vercel/static"
    },
    {
      "src": "mobile-server.html",
      "use": "@vercel/static"
    },
    {
      "src": "unified.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/mobile",
      "dest": "/mobile-server.html"
    },
    {
      "src": "/unified",
      "dest": "/unified.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client.html"
    }
  ]
}
